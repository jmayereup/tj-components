# TJ Components Environment Configuration Example
# Copy this file to .env and adjust values for self-hosting or custom backend setups.

# Shared Google Apps Script endpoint or custom submission URL for report cards & quiz submissions
VITE_SUBMISSION_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Default start quiz code required for students to open quizzes or authorize score submissions
VITE_TEACHER_CODE=6767

# Default teacher reset/unlock code required to reopen submitted tests or unlock security violations (e.g. tab switches)
VITE_RESET_CODE=7676
